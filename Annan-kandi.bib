	keywords = {Wearable sensors, Analysis, Classification, Data visualization, Injuries, Injury Prediction, KNN, Logistic regression, Logistic Regression, Machine learning, Measurement, Predictive models, Prevention and mitigation, Random Forest, Random forests, Training},
